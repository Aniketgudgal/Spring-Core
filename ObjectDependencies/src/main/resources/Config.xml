<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN 2.0//EN"
			"https://www.springframework.org/dtd/spring-beans-2.0.dtd">
<beans>
	<bean id = "student" class = "com.ObjectDepend.Student">
	<property name="person" ref = "person"></property>
	<property name="marks"><value>100</value></property>
	<property name="rollNo"><value>15</value></property>
	</bean>
	<bean id = "person" class = "com.ObjectDepend.Person">
		<property name="id"> <value>1</value></property>
		<property name="name"><value>Aniket</value></property>
		<property name="age"><value>22</value></property>
	</bean>
</beans>