<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN 2.0//EN" "https://www.springframework.org/dtd/spring-beans-2.0.dtd">
<beans>
	<bean id="student" class="com.dependencies.Student">
		<property name="data">
			<map>
				<entry key="1" value="aniket" />
				<entry key="2" value="Shivam" />
				<entry key="3" value="Gokul" />
			</map>
		</property>
	</bean>
	<bean id="emp" class="com.dependencies.Employee">
		<constructor-arg>
			<map>
				<entry key = "1" value = "aniket"/>
				<entry key = "2" value = "Shivam"/>
			</map>
		</constructor-arg>
	</bean>
</beans>